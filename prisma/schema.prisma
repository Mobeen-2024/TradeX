// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Strategy {
  id              String             @id @default(uuid())
  name            String
  description     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  // Relations
  versions        StrategyVersion[]
  runtime         StrategyRuntime?
  logs            ExecutionLog[]
  positions       Position[]
}

model StrategyVersion {
  id              String             @id @default(uuid())
  strategyId      String
  versionNumber   Int
  commitMessage   String
  isActive        Boolean            @default(false)
  createdAt       DateTime           @default(now())
  
  // Configuration State
  settings        Json?
  alloc           Float
  pairs           String             // SQLite serialization of pairs
  
  // Relations
  strategy        Strategy           @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  nodes           StrategyNode[]
  edges           StrategyEdge[]
}

model StrategyNode {
  id              String             @id
  versionId       String
  type            String
  label           String
  positionX       Float
  positionY       Float
  config          Json?
  
  version         StrategyVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
}

model StrategyEdge {
  id              String             @id
  versionId       String
  sourceNodeId    String
  targetNodeId    String
  sourceHandle    String?
  targetHandle    String?
  
  version         StrategyVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
}

model StrategyRuntime {
  strategyId      String             @id
  status          String             @default("PAUSED")
  roi             Float              @default(0)
  winRate         Float              @default(0)
  pnlUsdt         Float              @default(0)
  trades          Int                @default(0)
  errorCount      Int                @default(0)
  signalsProcessed Int               @default(0)
  lastPing        DateTime           @default(now())
  
  strategy        Strategy           @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model Position {
  id              String   @id @default(uuid())
  strategyId      String?
  pair            String
  type            String   // LONG, SHORT
  leverage        Int      @default(1)
  size            Float
  cost            Float
  entry           Float
  mark            Float    @default(0)
  pnl             Float?
  status          String   @default("OPEN") // OPEN, CLOSED
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  strategy        Strategy? @relation(fields: [strategyId], references: [id])
}

model ExecutionLog {
  id              String   @id @default(uuid())
  strategyId      String
  level           String   // INFO, EXEC, ERROR, WARN
  message         String
  nodeId          String?
  data            Json?
  timestamp       DateTime @default(now())
  strategy        Strategy @relation(fields: [strategyId], references: [id])
}

model AiAdvisory {
  id              String   @id @default(uuid())
  strategyId      String
  type            String   // RISK_ALERT, OPTIMIZATION, OPPORTUNITY
  severity        String   // low, medium, high
  message         String
  suggestion      String?
  impact          String?
  timestamp       DateTime @default(now())
  isApplied       Boolean  @default(false)
}
